<idea-plugin>
    <id>com.github.hon454.copy-selection-context</id>
    <name>Copy Selection Context</name>
    <vendor email="hon454@gmail.com" url="https://github.com/hon454">hon454</vendor>
    
    <description><![CDATA[
    Copy file path and line numbers to clipboard for easy AI context sharing.
    <br/>
    <br/>
    <strong>Features:</strong>
    <ul>
        <li>Copy relative or absolute file paths with line numbers</li>
        <li>Include code content in markdown format</li>
        <li>Toast notifications for copy confirmation</li>
        <li>Status bar widget showing last copied path</li>
        <li>Context menu integration</li>
        <li>Customizable keyboard shortcuts</li>
    </ul>
    ]]></description>
    
    <change-notes><![CDATA[
    <strong>1.0.0</strong>
    <ul>
        <li>Initial release</li>
        <li>Copy relative path with line numbers</li>
        <li>Copy absolute path with line numbers</li>
        <li>Copy with code content in markdown format</li>
        <li>Toast notifications and status bar widget</li>
        <li>Settings UI for default path type preference</li>
    </ul>
    ]]></change-notes>
    
    <depends>com.intellij.modules.platform</depends>
    
    <extensions defaultExtensionNs="com.intellij">
        <!-- Notification Group -->
        <notificationGroup id="CopySelectionContext" displayType="BALLOON"/>
        
        <!-- Settings Configurable -->
        <applicationConfigurable parentId="tools" instance="com.github.hon454.copyselectioncontext.CopySelectionConfigurable" id="CopySelectionContext.Settings" displayName="Copy Selection Context"/>
    </extensions>
    
    <actions>
        <!-- Main Action: Copy Selection Context (settings-driven) -->
        <action id="CopySelectionContext.Copy"
                class="com.github.hon454.copyselectioncontext.CopySelectionContextAction"
                text="Copy Selection Context"
                description="Copy file path and line numbers to clipboard (behavior configured in Settings)">
            <keyboard-shortcut keymap="$default" first-keystroke="control alt C"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt C" replace-all="true"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta alt C" replace-all="true"/>
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="EditorCopy"/>
        </action>
        
        <!-- Explicit Actions (context menu only, no shortcuts) -->
        <action id="CopySelectionContext.CopyRelativePath"
                class="com.github.hon454.copyselectioncontext.CopyRelativePathAction"
                text="Copy Relative Path with Line Numbers"
                description="Copy file path (relative to project root) and line numbers to clipboard">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="CopySelectionContext.Copy"/>
        </action>
        
        <action id="CopySelectionContext.CopyAbsolutePath"
                class="com.github.hon454.copyselectioncontext.CopyAbsolutePathAction"
                text="Copy Absolute Path with Line Numbers"
                description="Copy absolute file path and line numbers to clipboard">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="CopySelectionContext.CopyRelativePath"/>
        </action>
        
        <action id="CopySelectionContext.CopyWithCodeContent"
                class="com.github.hon454.copyselectioncontext.CopyWithCodeContentAction"
                text="Copy with Code Content"
                description="Copy file path, line numbers, and code content in markdown format">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="CopySelectionContext.CopyAbsolutePath"/>
        </action>
    </actions>
</idea-plugin>
